# Telegram
TELEGRAM_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Exchange
DEFAULT_EXCHANGE=mexc
MEXC_API_KEY=
MEXC_API_SECRET=
BINGX_API_KEY=
BINGX_API_SECRET=

# Safety defaults
LIVE_TRADING=false
BOT_VERSION=0029 AUTOPILOT HARDENED
DATABASE_PATH=bot_data.sqlite3

# Scanner defaults
UNIVERSE_MODE=adaptive
MAX_SYMBOLS=100
SCAN_INTERVAL_SEC=3
SYMBOL_REFRESH_SEC=300
MAX_OPEN_POSITIONS=5
RISK_PCT=0.005

# Strategy defaults
STRATEGY_MODE=hybrid
AUTO_STRATEGY_ADAPTATION=true
REGIME_ADAPTATION=true
MIRROR_MODE=off
SPOT_CONFIRMATION_ENABLED=true

# Sessions MSK
SESSION_FILTER_ENABLED=true
ASIA_OPEN_MSK=03:00
AMERICA_OPEN_MSK=16:30
SESSION_WINDOW_MIN=240
AMERICA_SHORT_BIAS_ENABLED=true

# Market protection
MAX_SPREAD_PCT=0.20
MAX_SLIPPAGE_PCT=0.20
MIN_DEPTH_USDT=5000
MAX_DAILY_LOSS_PCT=3.0
MAX_CONSECUTIVE_LOSSES=4
COOLDOWN_AFTER_CLOSE_SEC=120
LIMIT_TIMEOUT_SEC=30

# Proxy
PROXY_ENABLED=false
PROXY_URL=


# Signal Engine v0025
SIGNAL_MIN_CONFIDENCE=70
SIGNAL_OHLCV_TIMEFRAME=1m
SIGNAL_OHLCV_LIMIT=60
SIGNAL_VOLUME_SPIKE_MULT=1.8
SIGNAL_BREAKOUT_LOOKBACK=20
SIGNAL_MAX_CANDIDATES_PER_CYCLE=8
SIGNAL_MIN_24H_QUOTE_VOLUME=5000000
SIGNAL_MOMENTUM_THRESHOLD_PCT=0.18
SIGNAL_PULLBACK_RETRACE_MIN=0.20
SIGNAL_REVERSAL_WICK_MIN=0.35


# Execution v0026
DEFAULT_EQUITY_USDT=1000
MIN_ORDER_USDT=5
MAX_ORDER_USDT=100
TP_ATR_MULT=2.2
SL_ATR_MULT=1.2
MIN_TP_PCT=0.25
MAX_TP_PCT=1.20
MIN_SL_PCT=0.15
MAX_SL_PCT=0.60
TIME_STOP_SEC=300
BREAKEVEN_TRIGGER_PCT=0.30


# WebSocket hardening v0027
WS_ENABLED=true
WS_REQUIRE_HEALTHY_FOR_ENTRIES=true
WS_STALE_SEC=10
WS_PING_INTERVAL_SEC=15
WS_RECONNECT_BASE_SEC=1
WS_RECONNECT_MAX_SEC=30
WS_BINANCE_FUTURES_URL=wss://fstream.binance.com/ws/!miniTicker@arr

WEBSOCKET_ENABLED=true
PRODUCTION_GATE_ENABLED=true

ORDER_RETRY_ATTEMPTS=2
PROTECTION_ORDERS_ENABLED=true